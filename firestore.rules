rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı kendi verisine erişebilir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Kullanıcının altındaki TÜM belge ve koleksiyonlara sınırsız, derinlemesine izin:
      // (expenses, incomes, assets, paymentMethods, settings, profile/info vb.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Error logs - sadece authenticated kullanıcılar yazabilir
    match /errorLogs/{logId} {
      allow create: if request.auth != null;
      allow read, delete: if false; // Admin SDK ile okunur
    }

    // Şifre sıfırlama OTP'leri
    // Giriş yapmamış kullanıcılar PIN sıfırlama isteyebilmeli — auth zorunlu değil.
    // OTP, SHA-256 hash olarak saklandığından düz metin açığı yok.
    // Brute force koruması uygulama katmanında (5 deneme) uygulanıyor.
    match /password_reset_otps/{email} {
      allow read, write: if true;
    }

    // Diğer tüm yollar kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
