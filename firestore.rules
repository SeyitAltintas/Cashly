rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı kendi verisine erişebilir
    match /users/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        // Veri bütünlüğü: Negatif tutar (amount) veya geçersiz veri tiplerini engelle
        && (!('amount' in request.resource.data) || request.resource.data.amount >= 0)
        // Red Team Yaması: Financial DoS engellemek için döküman boyutu limitlendi
        && request.resource.data.toString().size() < 5000;

      // Kullanıcının altındaki TÜM belge ve koleksiyonlara izin
      match /{document=**} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId
          && (!('amount' in request.resource.data) || request.resource.data.amount >= 0)
          && request.resource.data.toString().size() < 5000;
      }
    }

    // Error logs - sadece authenticated kullanıcılar yazabilir. Boyut ve format kısıtlaması eklendi.
    match /errorLogs/{logId} {
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAny(['error', 'message'])
                    && request.resource.data.toString().size() < 2000;
      allow read, delete: if false; // Admin SDK ile okunur
    }

    // Diğer tüm yollar kapalı
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
